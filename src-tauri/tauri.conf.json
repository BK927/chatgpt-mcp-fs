{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ChatGPT MCP FS",
  "version": "0.1.0",
  "identifier": "com.chatgpt-mcp-fs.dev",
  "build": {
    "frontendDist": "../src/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm build:server && pnpm dev",
    "beforeBuildCommand": "pnpm build:server && pnpm build:frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "ChatGPT MCP File System",
        "width": 800,
        "height": 600,
        "resizable": true,
        "minWidth": 600,
        "minHeight": 400
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "resources": {
      "../packages/mcp-server/dist": "packages/mcp-server/dist"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": [
          "Korean",
          "English"
        ],
        "displayLanguageSelector": true
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}