{
  "name": "@chatgpt-mcp-fs/server",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=cjs --outfile=dist/index.js --external:@node-rs/argon2 --external:@node-rs/bcrypt",
    "build:types": "tsc --emitDeclarationOnly --declaration --outDir dist",
    "dev": "esbuild src/index.ts --bundle --platform=node --format=cjs --outfile=dist/index.js --watch",
    "start": "node dist/index.js",
    "inspector": "npx @modelcontextprotocol/inspector node dist/index.js"
  },
  "dependencies": {
    "@chatgpt-mcp-fs/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "cors": "^2.8.6",
    "express": "^4.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.6.0"
  }
}
